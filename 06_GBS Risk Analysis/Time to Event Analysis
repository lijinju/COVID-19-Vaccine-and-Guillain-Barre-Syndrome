            legend.title = element_text(size = 18),
            legend.text = element_text(size = 18),
            plot.margin = margin(10, 10, 10, 10),
            panel.border = element_blank()
        )
    )  
        
    print(ab)
    print(plot)
}


# ============================================================================
# FUNCTION 6: Cox Model for Vaccine Platform Comparison
# Input: demo_GBS (vaccine cohort with vac_type)
# ============================================================================

Cox_vaccine_platform <- function(demo_GBS) {
        
    library(survival)
    library(survminer)

    # Filter to vaccine group only
    subset_data <- demo_GBS[demo_GBS$group_id == 1,]
    subset_data$vac_type <- factor(subset_data$vac_type)

    cox_model <- coxph(Surv(GBS_interval_2, GBS) ~ vac_type, data = subset_data)
    
    plot <- ggforest(
        cox_model,
        data = subset_data,
        main = 'Hazard Ratio by Vaccine Type',
        fontsize = 1,
        noDigits = 2
    )
    
    print(plot)
    
    return(summary(cox_model))
}


# ============================================================================
# FUNCTION 7: First vs Second Dose Comparison
# Input: first_second_shots (cohort with groupid for 1st vs 2nd dose)
# ============================================================================

Cox_first_vs_second_dose <- function(first_second_shots) {

    library(survival)
    library(survminer)

    first_second_shots$group_id <- as.factor(first_second_shots$group_id)
    first_second_shots$group_id <- factor(first_second_shots$group_id, labels = c('1st', '2nd'))
    first_second_shots$group_id <- relevel(first_second_shots$group_id, ref = "1st")

    cox_model <- coxph(
        Surv(GBS_interval_2, GBS) ~ groupid + Age + Gender + Race + Ethnicity + 
        Total_Visits + AKIHistory + Hypertension + Diabetes_mellitus + 
        Heart_failure + Cardiovascular_disease + Obesity + Hypothyroidism + 
        Asthma + COPD + Hyperlipidemia + Stroke + Cancer + 
        Neurological_disorder + Autoimmune_disease, 
        data = first_second_shots
    )

    mul_cox <- summary(cox_model)
    mul_HR <- round(mul_cox$coefficients[,2], 2) 
    mul_Pvalue <- round(mul_cox$coefficients[,5], 4) 
    mul_CI5 <- round(mul_cox$conf.int[,3], 2)
    mul_CI95 <- round(mul_cox$conf.int[,4], 2)
    mul_CI <- paste0(mul_HR, ' (', mul_CI5, '-', mul_CI95, ')')
    Variable <- row.names(data.frame(mul_cox$coefficients))
    
    mulcox_res <- data.frame(Variable, aHR = mul_HR, CI5 = mul_CI5, CI95 = mul_CI95, 
                              `95_CI` = mul_CI, Pvalue = mul_Pvalue)
    colnames(mulcox_res) <- c("Variable", "aHR", "CI5", "CI95", "95_CI", "Pvalue")

    return(mulcox_res)
}