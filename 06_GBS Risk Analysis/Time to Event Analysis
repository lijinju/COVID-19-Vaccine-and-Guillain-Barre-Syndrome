# ============================================================================
# FUNCTION 4: Cox Proportional Hazards Model (Multivariable)
# Input: demo_gbs (cohort with demographics and comorbidities)
# ============================================================================

Cox_multivariable <- function(demo_gbs) {
  
    library(survival)
    library(survminer)
  
    # Convert columns to factors and set reference levels
    demo_gbs$group_id <- as.factor(demo_gbs$group_id)
    demo_gbs$group_id <- factor(demo_gbs$group_id, labels = c('Infection', 'NC'))
    demo_gbs$group_id <- relevel(demo_gbs$group_id, ref = "NC")
  
    demo_gbs$Race <- as.factor(demo_gbs$Race)
    demo_gbs$Race <- relevel(demo_gbs$Race, ref = "White")
  
    demo_gbs$Gender <- factor(demo_gbs$Gender, labels = c('female', 'male', 'unknown'))
  
    # Fit Cox model
    cox_model <- coxph(
        Surv(GBS_interval_2, GBS) ~ group_id + Age + Gender + Race + Ethnicity + 
        Total_Visits + AKIHistory + Hypertension + Diabetes_mellitus + 
        Heart_failure + Cardiovascular_disease + Obesity + Hypothyroidism + 
        Asthma + COPD + Hyperlipidemia + Stroke + Cancer + 
        Neurological_disorder + Autoimmune_disease, 
        data = demo_gbs
    )  
  
    # Create forest plot
    coxplot <- ggforest(
        cox_model,
        data = demo_gbs,
        fontsize = 1,
        noDigits = 2,
        main = "Hazard Ratios of Demographic and Comorbidity Factors"
    )  

    print(coxplot)

    # Extract results
    mul_cox <- summary(cox_model)
    mul_HR <- mul_cox$coefficients[,2] 
    mul_Pvalue <- mul_cox$coefficients[,5] 
    mul_CI5 <- round(mul_cox$conf.int[,3], 2)
    mul_CI95 <- round(mul_cox$conf.int[,4], 2)
    mul_CI <- paste0(round(mul_HR, 2), ' (', mul_CI5, '-', mul_CI95, ')')
    Variable <- row.names(data.frame(mul_cox$coefficients))
    
    mulcox_res <- data.frame(
        Variable, 
        HR = round(mul_HR, 2), 
        CI5 = mul_CI5, 
        CI95 = mul_CI95, 
        `HR (95% CI)` = mul_CI, 
        Pvalue = round(mul_Pvalue, 4)
    )
    colnames(mulcox_res) <- c("Variable", "HR", "CI5", "CI95", "HR (95% CI)", "Pvalue")

    return(mulcox_res)
}


# ============================================================================
# FUNCTION 5: Time Period Stratified KM (P1, P2, P3)
# Input: cohort_censored (with time_period_strains column)
# ============================================================================

KM_by_time_period <- function(cohort_censored, period) {     
    
    library(survival)
    library(survminer)

    # Filter by period (P1, P2, or P3)
    subset_data <- cohort_censored[cohort_censored$time_period_strains == period,]
    subset_data <- subset_data[subset_data$group_id != 3, ]  # Remove control

    KM <- survfit(Surv(GBS_interval_2, has_GBS) ~ group_id, data = subset_data)
    KM$surv <- 1 - KM$surv
    
    ab <- summary(KM, times = c(0, 10, 20, 30))

    plot <- ggsurvplot(
        KM,           
        conf.int = FALSE,  
        ylab = expression(bold("Probability of Developing GBS, %")),
        xlab = expression(bold("Days")),
        ylim = c(0, 0.0001),
        break.x.by = 5,
        palette = c("#E7B800", "#2E9FDF"),
        title = paste("30-Day GBS Incidence Rate -", period),
        font.title = c(16, "bold", "Darkblue"),
        censor.shape = "|", 
        censor.size = 4,
        size = 1.5,
        pval = TRUE,
        pval.method = TRUE,
        pval.coord = c(0, 0.00009),
