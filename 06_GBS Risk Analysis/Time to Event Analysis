# ============================================================================
# survival_analysis.R
# Description: Kaplan-Meier survival analysis and Cox regression for GBS risk
# Compares time-to-GBS across exposure groups from your pipeline
# ============================================================================

# Load required libraries
library(survival)
library(survminer)
library(ggplot2)
library(dplyr)

# ============================================================================
# FUNCTION 1: Main KM Plot (3 groups: Vaccination, Infection, Control)
# Input: cohort_censored (final censored cohort)
# ============================================================================

KM_main <- function(cohort_censored) {
    
    library(survival)
    library(survminer)

    # Fit KM curve
    KM <- survfit(Surv(GBS_interval_2, has_GBS) ~ group_id, data = cohort_censored)
    
    # Convert to cumulative incidence (1 - survival)
    KM$surv <- 1 - KM$surv

    # Summary at specific time points
    ab <- summary(KM, times = c(0, 10, 20, 30))
    
    # Create plot
    plot <- ggsurvplot(
        KM,           
        conf.int = FALSE,  
        ylab = expression(bold("Probability of Developing GBS, %")),
        xlab = expression(bold("Days")),
        ylim = c(0, 0.0001),
        break.x.by = 5,
        palette = c("red", "green", "darkblue"),
        title = "30-Day GBS Incidence Rate after Exposure to COVID-19 Antigens",
        font.title = c(16, "bold", "Darkblue"),
        censor.shape = "|", 
        censor.size = 4,
        size = 1.5,
        pval = TRUE,
        pval.method = TRUE,
        pval.coord = c(0, 0.00009),
        legend.title = "",           
        legend.labs = c('Vaccination', 'Infection', "Negative control"),  
        risk.table = TRUE,            
        risk.table.height = 0.25, 
        risk.table.y.text = FALSE,
        risk.table.y.text.col = T,
        surv.plot.height = 0.75,
        data = cohort_censored,
        ggtheme = theme_minimal() + theme(
            panel.grid.major.x = element_blank(),
            panel.grid.minor.x = element_blank(),
            panel.grid.major.y = element_line(color = "grey80"),
            panel.grid.minor.y = element_blank(),
            axis.line = element_line(color = "black"),
            axis.title.x = element_text(size = 18, color = "black"),
            axis.title.y = element_text(size = 18, color = "black", margin = margin(r = 20)),
            axis.text.x = element_text(size = 18, color = "black", margin = margin(t = 10)),
            axis.text.y = element_text(size = 18, color = "black"),
            plot.title = element_text(size = 18, color = "darkblue"),
            legend.title = element_text(size = 18),
            legend.text = element_text(size = 18),
            plot.margin = margin(10, 10, 10, 10),
            panel.border = element_blank()
        )
    )  
        
    print(ab)
    print(plot)
}


