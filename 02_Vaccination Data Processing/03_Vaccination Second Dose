/*
================================================================================
File: Vaccination_Fact_SecondDose.sql
Description: Build vaccination fact table focused on second dose analysis
================================================================================
*/


WITH RankedVaccinations AS (
    SELECT
        person_id,
        drug_exposure_start_date AS vaccinated_date,
        drug_concept_name,
        ROW_NUMBER() OVER (PARTITION BY person_id ORDER BY drug_exposure_start_date ASC) AS vaccination_rank
    FROM Pre_covid_vaccine_all_record
    WHERE drug_exposure_start_date >= '2020-12-11'
)
SELECT 
    person_id,
    -- First shot
    MAX(CASE WHEN vaccination_rank = 1 THEN vaccinated_date END) AS first_shot,
    MAX(CASE WHEN vaccination_rank = 1 THEN drug_concept_name END) AS first_shot_concept,
    
    -- Second shot
    MAX(CASE WHEN vaccination_rank = 2 THEN vaccinated_date END) AS second_shot,
    MAX(CASE WHEN vaccination_rank = 2 THEN drug_concept_name END) AS second_shot_concept,
    
    -- Third shot (booster)
    MAX(CASE WHEN vaccination_rank = 3 THEN vaccinated_date END) AS third_shot,
    MAX(CASE WHEN vaccination_rank = 3 THEN drug_concept_name END) AS third_shot_concept,
    
    -- Interval between first and second shot (days)
    DATEDIFF(
        MAX(CASE WHEN vaccination_rank = 2 THEN vaccinated_date END),
        MAX(CASE WHEN vaccination_rank = 1 THEN vaccinated_date END)
    ) AS days_between_first_second,
    
    -- Interval between second and third shot (days)
    DATEDIFF(
        MAX(CASE WHEN vaccination_rank = 3 THEN vaccinated_date END),
        MAX(CASE WHEN vaccination_rank = 2 THEN vaccinated_date END)
    ) AS days_between_second_third,
    
    -- Flags for second dose analysis
    CASE 
        WHEN MAX(CASE WHEN vaccination_rank = 2 THEN vaccinated_date END) IS NOT NULL THEN 1 
        ELSE 0 
    END AS has_second_dose,
    
    CASE 
        WHEN MAX(CASE WHEN vaccination_rank = 3 THEN vaccinated_date END) IS NOT NULL THEN 1 
        ELSE 0 
    END AS has_third_dose

FROM RankedVaccinations
GROUP BY person_id
HAVING first_shot IS NOT NULL
ORDER BY person_id;
